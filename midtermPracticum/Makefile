.PHONY: all test compile e1 e2 e3 e4 m1 m2 m3 clean

# Default behavior when just typing "make"
all: test

# The complete test suite
test:
	bash grade.sh all

# Just check if it compiles for Base Credit
compile:
	bash grade.sh compile

# --- Individual Tests ---

e1:
	bash grade.sh e1

e2:
	bash grade.sh e2

e3:
	bash grade.sh e3

e4:
	bash grade.sh e4

m1:
	bash grade.sh m1

m2:
	bash grade.sh m2

m3:
	bash grade.sh m3

submit:
	~/bin/submit -c=SI266 -p=midterm exam.c

# Cleanup dummy files generated by the testing process
clean:
	rm -f test_driver test_e1.txt test_e2.txt relay_out.txt dummy_cmd
